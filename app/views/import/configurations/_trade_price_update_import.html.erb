<%# locals: (import:) %>

<%= styled_form_with model: @import, url: import_configuration_path(@import), scope: :import, method: :patch, class: "space-y-4" do |form| %>
  <div class="space-y-4">
    <%= form.select :external_id_col_label, import.csv_headers, { include_blank: t("imports.form.select_column"), label: t("imports.form.external_id") }, required: true %>
    <%= form.select :price_col_label, import.csv_headers, { include_blank: t("imports.form.select_column"), label: t("imports.form.price") }, required: true %>
    <%= form.select :fee_col_label, import.csv_headers, { include_blank: t("imports.form.leave_empty"), label: t("imports.form.fee") } %>
    <%= form.select :number_format, Import::NUMBER_FORMATS.keys, { label: t("imports.form.format"), prompt: t("imports.form.select_format") }, required: true %>
  </div>

  <%= form.submit t("imports.form.apply_configuration"), disabled: import.complete? %>
<% end %>
