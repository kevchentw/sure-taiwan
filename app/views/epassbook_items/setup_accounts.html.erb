<% content_for :title, t(".title") %>

<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: t(".title")) %>

  <% dialog.with_body do %>
    <% if @epassbook_accounts.empty? %>
      <div class="text-sm text-secondary p-4">
        <p><%= t(".no_accounts") %></p>
        <%= link_to t(".back"), accounts_path, class: "btn mt-4" %>
      </div>
    <% else %>
      <%= form_with url: complete_account_setup_epassbook_item_path(@epassbook_item),
                    method: :post,
                    local: true,
                    data: { turbo_frame: "_top" },
                    class: "space-y-6" do |form| %>

        <div class="space-y-4">
          <% @epassbook_accounts.each do |ea| %>
            <% default_type    = ea.stock? ? "Investment" : "Depository" %>
            <% default_subtype = ea.stock? ? "tw_brokerage" : "checking" %>

            <div class="border border-primary rounded-lg p-4">
              <div class="mb-3">
                <h3 class="font-medium text-primary"><%= ea.display_name %></h3>
                <p class="text-sm text-secondary">
                  <%= ea.currency %> •
                  <%= ea.stock? ? t(".stock_account") : t(".bank_account") %>
                  <% if ea.current_balance.present? %>
                    • <%= number_to_currency(ea.current_balance, unit: ea.currency) %>
                  <% end %>
                </p>
              </div>

              <div class="space-y-3">
                <div>
                  <%= label_tag "account_types[#{ea.id}]", t(".account_type_label"), class: "block text-sm font-medium text-primary mb-1" %>
                  <%= select_tag "account_types[#{ea.id}]",
                                 options_for_select(
                                   [ [ t(".skip"), "skip" ],
                                     [ t(".investment_type"), "Investment" ],
                                     [ t(".depository_type"), "Depository" ] ],
                                   default_type
                                 ),
                                 class: "appearance-none bg-container border border-primary rounded-md px-3 py-2 text-sm w-full" %>
                </div>

                <div>
                  <%= label_tag "account_subtypes[#{ea.id}]", t(".subtype_label"), class: "block text-sm font-medium text-primary mb-1" %>
                  <% if ea.stock? %>
                    <%= select_tag "account_subtypes[#{ea.id}]",
                                   options_for_select(@investment_subtype_options, default_subtype),
                                   class: "appearance-none bg-container border border-primary rounded-md px-3 py-2 text-sm w-full" %>
                  <% else %>
                    <%= select_tag "account_subtypes[#{ea.id}]",
                                   options_for_select(@depository_subtype_options, default_subtype),
                                   class: "appearance-none bg-container border border-primary rounded-md px-3 py-2 text-sm w-full" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="flex gap-3">
          <%= render DS::Button.new(text: t(".create_accounts"), variant: "primary", icon: "plus", type: "submit", class: "flex-1") %>
          <%= render DS::Link.new(text: t(".cancel"), variant: "secondary", href: accounts_path) %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>
