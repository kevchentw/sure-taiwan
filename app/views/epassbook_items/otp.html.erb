<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: t(".title")) %>

    <% dialog.with_body do %>
      <p class="text-sm text-secondary mb-4"><%= t(".description") %></p>

      <% if @error_message.present? %>
        <div class="mb-4 p-3 rounded-md bg-destructive/10 text-destructive text-sm">
          <%= @error_message %>
        </div>
      <% end %>

      <%= form_with url: verify_otp_epassbook_item_path(@epassbook_item), method: :post, data: { turbo: true, turbo_frame: "_top" } do |f| %>
        <div class="space-y-3">
          <div>
            <%= label_tag :otp_code, t(".otp_code_label"), class: "text-sm text-secondary block mb-1" %>
            <%= text_field_tag :otp_code, nil, class: "input", inputmode: "numeric", autocomplete: "one-time-code", maxlength: 8 %>
          </div>
          <div class="flex items-center gap-2 justify-end pt-2">
            <%= link_to t(".cancel"), accounts_path, class: "btn", data: { turbo_frame: "_top", action: "DS--dialog#close" } %>
            <%= submit_tag t(".verify"), class: "btn btn--primary" %>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>
